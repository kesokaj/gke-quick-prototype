# =============================================================================
# GKE Cluster Configuration
# =============================================================================
# Copy this file to .env and customize:  cp .env.example .env
#
# All variables used by cluster.sh. Override any value here.
# Empty values = flag not used (gcloud defaults apply).
# true/false values = explicit enable/disable.

# --- Project & Region --------------------------------------------------------
PROJECT=""                              # GCP project ID (default: gcloud config)
CLUSTER_NAME="my-cluster"               # Cluster name
REGION="europe-west4"                   # GCP region
RELEASE_CHANNEL="REGULAR"               # GKE release channel (rapid/regular/stable)

# --- Network -----------------------------------------------------------------
VPC="my-network"                        # VPC network name
SUBNET="my-subnet-europe-west4"         # Subnet name
SUBNET_RANGE="10.10.0.0/20"             # Subnet primary CIDR
SUBNET_SECONDARY_PODS="10.100.0.0/16"   # Pods secondary range CIDR
SUBNET_SECONDARY_SERVICE="10.200.0.0/20" # Services secondary range CIDR
PODS_RANGE_NAME="pods"                  # Secondary range name for pods
SERVICES_RANGE_NAME="services"          # Secondary range name for services
ENABLE_CLOUD_NAT="true"                 # Create Cloud NAT for private nodes (true/false)

# --- Default Pool ------------------------------------------------------------
MACHINE_TYPE="n2d-standard-4"           # Machine type
DISK_TYPE="pd-ssd"                      # Boot disk type
DISK_SIZE="100"                         # Boot disk size (GB)
NUM_NODES="1"                           # Fixed nodes per zone (no autoscaling)
MAX_PODS_PER_NODE="64"                  # Max pods per node
DEFAULT_GVNIC=""                        # Google Virtual NIC (true=enable, empty=skip)
DEFAULT_SHIELDED_SECURE_BOOT=""         # Shielded: secure boot (true=enable, empty=skip)
DEFAULT_SHIELDED_INTEGRITY=""           # Shielded: integrity monitoring (true=enable, empty=skip)
DEFAULT_AUTO_REPAIR="true"              # Auto repair (true/false)
DEFAULT_AUTO_UPGRADE="true"             # Auto upgrade (true/false, must be true with release channel)

# --- Secondary Pool ----------------------------------------------------------
SECONDARY_MACHINE_TYPE="n2-standard-4"  # Machine type
SECONDARY_DISK_TYPE="pd-ssd"            # Boot disk type
SECONDARY_DISK_SIZE="100"               # Boot disk size (GB)
SECONDARY_IMAGE_TYPE="COS_CONTAINERD"   # Node image (COS_CONTAINERD/UBUNTU_CONTAINERD)
#
# Autoscaling — set to "true" to enable. Requires MIN_NODES and MAX_NODES.
SECONDARY_AUTOSCALING="false"           # Enable autoscaling (true/false)
SECONDARY_NUM_NODES="0"                 # Initial nodes per zone
SECONDARY_MIN_NODES="0"                 # Autoscaling total min (used when AUTOSCALING=true)
SECONDARY_MAX_NODES="10"                # Autoscaling total max (used when AUTOSCALING=true)
#
SECONDARY_MAX_PODS_PER_NODE="64"        # Max pods per node
SECONDARY_MAX_SURGE=""                  # Surge upgrade (empty=skip)
SECONDARY_MAX_UNAVAILABLE=""            # Max unavailable during upgrade (empty=skip)
SECONDARY_SPOT=""                       # Use Spot VMs (true=enable, empty=skip)
SECONDARY_LOCATION_POLICY="ANY"         # Location policy (ANY/BALANCED)
SECONDARY_GVNIC=""                      # Google Virtual NIC (true=enable, empty=skip)
SECONDARY_SHIELDED_SECURE_BOOT=""       # Shielded: secure boot (true=enable, empty=skip)
SECONDARY_SHIELDED_INTEGRITY=""         # Shielded: integrity monitoring (true=enable, empty=skip)
#
# Nested virtualization — set to "true" to enable. Requires THREADS_PER_CORE.
SECONDARY_NESTED_VIRT=""                # Nested virtualization (true/false, empty=skip)
SECONDARY_THREADS_PER_CORE=""           # SMT / hyperthreading (used when NESTED_VIRT=true, 1=off, 2=on)
#
SECONDARY_AUTO_REPAIR="true"            # Auto repair (true/false)
SECONDARY_AUTO_UPGRADE="true"           # Auto upgrade (true/false, must be true with release channel)
SECONDARY_TAGS=""                       # Network tags (comma-separated, empty=skip)
SECONDARY_LABELS=""                     # Node labels (key=val,key=val, empty=skip)
SECONDARY_TAINTS=""                     # Node taints (key=val:effect, empty=skip)
